# =============================================================
# Public env vars — exposed to the browser via config.js
# =============================================================

# Your Sanity project ID. Find at https://sanity.io/manage
SANITY_PROJECT_ID=

# Sanity dataset name. Default is "production".
SANITY_DATASET=production

# Sanity API version. Pin a date so future Sanity changes don't break you.
SANITY_API_VERSION=2024-01-01

# Public site URL — used for canonical/OG meta. Optional.
SITE_ORIGIN=https://yourdomain.com

# Snipcart public API key. Safe to expose to the browser.
# Find at https://app.snipcart.com → Account → API Keys → Public.
# Leave blank to disable cart entirely (Adopt CTAs fall back to a link to /store.html).
SNIPCART_PUBLIC_API_KEY=

# Snipcart library version. Pinned so vendor changes can't break checkout silently.
SNIPCART_VERSION=3.7.1

# =============================================================
# SECRETS — server-only. Never sent to the browser.
# =============================================================

# Loops API key. Find at https://app.loops.so/settings/api
LOOPS_API_KEY=

# Loops "Mailing List" id newsletter subscribers should join.
# In Loops UI → Audience → Mailing Lists → copy the ID from the URL.
LOOPS_MAILING_LIST_ID=

# Loops "Event" name to fire when a Sanity drop is published.
# Set up the matching event-triggered loop in Loops UI to send the drop email.
LOOPS_DROP_EVENT_NAME=drop_published

# Loops Transactional template id used for contact form submissions.
# Loops UI → Transactional → New Template → copy the id from the URL.
# Template should reference: {{name}}, {{fromEmail}}, {{subject}}, {{message}},
# {{inquiryType}}, {{submittedAt}}.
LOOPS_CONTACT_TRANSACTIONAL_ID=

# Optional Loops Transactional template id for the auto-reply sent back to the
# person who filled out the contact form. Leave blank to skip the auto-reply.
# Template should reference: {{name}}, {{subject}}, {{inquiryType}}.
LOOPS_CONTACT_CONFIRMATION_ID=

# Email address that receives contact-form submissions (the "workshop inbox").
CONTACT_RECIPIENT_EMAIL=

# Random string. Paste the same value into Sanity's webhook "Secret" field
# so the webhook handler can verify incoming requests are really from Sanity.
SANITY_WEBHOOK_SECRET=

# Sanity write token (only needed if you want the webhook handler to mark
# drops as "emailSentAt" so they don't double-send). Create at:
# https://sanity.io/manage → API → Tokens → Add token (Editor permissions).
SANITY_WRITE_TOKEN=
